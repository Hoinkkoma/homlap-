%%{init: {"theme": "neo-dark", "layout": "elk"}}%%
flowchart LR

    subgraph Zuhause["🏠 Zuhause"]
      direction TB
      fritzbox[("Router Fritzbox")]
      subgraph beimir["Immer am Mann"]
        phone["Nothing Phone 2a"]
        buds["Nothing Buds 2a"]
        watch["Xiaomi Watch"]
      end
      subgraph Arbeit
        thinkbook["ThinkBook"]
        tablet["Tablet Lenovo"]
      end
      subgraph Admin
        thinkpad["ThinkPad T490s"]
      end
      phone -.->|"🔵 Bluetooth"| buds
      phone -.->|"🔵 Bluetooth"| watch
      fritzbox -.->|"📶 WLAN"| phone
      fritzbox -.->|"📶 WLAN"| thinkbook
      fritzbox -->|"🔌 LAN"| thinkpad
    end

    subgraph Homelab["⚙️ Homelab"]
      direction TB
      subgraph debiansvr["🖥️ Debian Server"]
        tailscale_d[["⚡ Tailscale (VPN-Hub)"]]
        upkuma["Uptime Kuma"]
        ph["Pi-Hole"]
        homepg["Homepage"]
      end
      subgraph proxmox["🔶 Proxmox"]
        direction TB
        subgraph vm["💻 VM"]
          deb12vm["Debian 12"]
        end
        subgraph lxc["📦 Container LXC"]
          deb12ct["Debian 12"]
        end
        subgraph storage["💾 Storage"]
          zfs["ZFS Pool"]
          subgraph programs["📂 Programme"]
            tailscale_px["Tailscale"]
            pihole_px["Pi-Hole"]
            immich_px["Immich"]
            ittools_px["IT-Tools"]
            netdata_px["Netdata"]
            clam_px["ClamAV"]
          end
        end
      end
      tailscale_d --> upkuma
      tailscale_d --> ph
      tailscale_d --> homepg
      tailscale_d -->|"🔒 VPN Tunnel"| tailscale_px
    end

    subgraph HomeDash["📊 Homepage Dashboard"]
      direction LR
      hp_debian["🖥️ Debian Server"]
      hp_proxmox["🔶 Proxmox"]
      hp_tailscale["🔒 Tailscale"]
      hp_pihole["🚫 Pi-Hole"]
      hp_upkuma["💚 Uptime Kuma"]
      hp_youtube["▶️ YouTube"]
      hp_disney["🏰 Disney+"]
      hp_netflix["🎬 Netflix"]
      hp_prime["📦 Amazon Prime"]
      hp_reddit["🤖 Reddit"]
    end

    subgraph Cloud["☁️ Cloud"]
      subgraph Microsoft
        onedrive["OneDrive"]
        auth["Authenticator"]
        github["GitHub"]
        mermaid_c["Mermaid"]
      end
      subgraph Google
        drive["Drive"]
        gmail["Mails"]
        photos["Fotos"]
      end
      subgraph Freizeit
        steam["Steam"]
        battlenet["Battle.net"]
        netflix_c["Netflix"]
        disney_c["Disney+"]
        prime_c["Amazon Prime"]
        music["Amazon Music"]
        youtube_c["YouTube"]
        discord["Discord"]
        reddit_c["Reddit"]
      end
    end

    fritzbox -->|"🔌 LAN"| tailscale_d
    fritzbox -->|"🔌 LAN"| proxmox
    thinkpad  -->|"🔒 VPN"| tailscale_d
    thinkbook -.->|"🔒 VPN"| tailscale_d
    phone     -.->|"🔒 VPN"| tailscale_d
    tailscale_d ==>|"🌐 Internet"| Cloud

    homepg -->|"🔌 LAN"| hp_debian
    homepg -->|"🔌 LAN"| hp_proxmox
    homepg -->|"🔌 LAN"| hp_tailscale
    homepg -->|"🔌 LAN"| hp_pihole
    homepg -->|"🔌 LAN"| hp_upkuma
    homepg ==>|"🌐 Internet"| hp_youtube
    homepg ==>|"🌐 Internet"| hp_disney
    homepg ==>|"🌐 Internet"| hp_netflix
    homepg ==>|"🌐 Internet"| hp_prime
    homepg ==>|"🌐 Internet"| hp_reddit

    classDef ZuhauseStyle fill:#1e3a8a,stroke:#6366f1,color:#f9fafb;
    classDef HomelabStyle fill:#064e3b,stroke:#2dd4bf,color:#f0fdfa;
    classDef CloudStyle fill:#3b0764,stroke:#a78bfa,color:#f5f3ff;
    classDef VpnHubStyle fill:#065f46,stroke:#10b981,color:#ecfdf5,font-weight:bold;
    classDef HomepageStyle fill:#7c2d12,stroke:#f97316,color:#fff7ed;
    classDef StorageStyle fill:#1e3a5f,stroke:#60a5fa,color:#eff6ff;
    classDef ProgramStyle fill:#312e81,stroke:#818cf8,color:#eef2ff;
    classDef VMStyle fill:#14532d,stroke:#4ade80,color:#f0fdf4;

    class fritzbox,phone,buds,watch,thinkbook,tablet,thinkpad ZuhauseStyle;
    class upkuma,ph,homepg HomelabStyle;
    class deb12vm,deb12ct VMStyle;
    class zfs StorageStyle;
    class tailscale_px,pihole_px,immich_px,ittools_px,netdata_px,clam_px ProgramStyle;
    class drive,gmail,photos,onedrive,auth,github,mermaid_c,steam,battlenet,netflix_c,disney_c,prime_c,music,youtube_c,discord,reddit_c CloudStyle;
    class tailscale_d VpnHubStyle;
    class hp_debian,hp_proxmox,hp_tailscale,hp_pihole,hp_upkuma,hp_youtube,hp_disney,hp_netflix,hp_prime,hp_reddit HomepageStyle;
